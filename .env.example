# 智能旅行助手 环境变量配置
# 请根据实际情况修改以下配置

# ==================== API 密钥和地址 ====================
# API 密钥（用于访问大模型服务）
API_KEY=sk-xxx

# API 基础 URL（大模型服务的地址）
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== 大模型参数配置 ====================
# 模型名称
LLM_MODEL=qwen3.5-flash

# 温度参数（控制随机性，0-1之间，越小越确定）
LLM_TEMPERATURE=0.1

# 是否启用流式响应
LLM_STREAMING=True

# 是否启用思考模式
LLM_ENABLE_THINKING=False

# ==================== MySQL 数据库配置 ====================
# MySQL 主机地址
# - 本地运行：使用 localhost 或 127.0.0.1
# - Docker 运行：使用服务名称（已在 docker-compose.yml 中配置）
# - 不设置时会自动检测运行环境并使用合适的默认值
# MYSQL_HOST=localhost
# MySQL 端口
MYSQL_PORT=3306
# MySQL 用户名
MYSQL_USER=root
# MySQL 密码
MYSQL_PASSWORD=12345678
# MySQL 数据库名
MYSQL_DATABASE=smart_travel

# ==================== Milvus 向量数据库配置 ====================
# Milvus 主机地址
# - 本地运行：使用 localhost 或 127.0.0.1
# - Docker 运行：使用服务名称（已在 docker-compose.yml 中配置）
# - 不设置时会自动检测运行环境并使用合适的默认值
# MILVUS_HOST=localhost
# Milvus 端口
MILVUS_PORT=19530

# ==================== MCP 服务器地址配置 ====================
# MCP 服务器 URL（A2A 服务连接 MCP 服务使用）
# - 本地运行：使用 localhost
# - Docker 运行：使用服务名称（已在 docker-compose.yml 中配置）
# - 不设置时使用默认值：http://localhost:800X/mcp
# TICKET_MCP_URL=http://localhost:8001/mcp
# WEATHER_MCP_URL=http://localhost:8002/mcp
# TRIP_MCP_URL=http://localhost:8003/mcp
# GUIDE_MCP_URL=http://localhost:8004/mcp

# ==================== A2A 服务器地址配置 ====================
# A2A 服务器 URL（主助手连接子代理使用）
# - 本地运行：使用 localhost
# - Docker 运行：使用服务名称（已在 docker-compose.yml 中配置）
# - 不设置时使用默认值：http://localhost:500X
# WEATHER_A2A_URL=http://localhost:5005
# TICKET_A2A_URL=http://localhost:5006
# TRIP_A2A_URL=http://localhost:5007
# GUIDE_A2A_URL=http://localhost:5008

# ==================== LangSmith 可观测性（可选） ====================
# 配置后自动追踪所有 LangChain/LangGraph 调用链路
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_PROJECT=smart-travel-assistant
