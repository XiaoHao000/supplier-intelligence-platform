# ==================== 智能旅行助手（Smart Travel）环境变量模板 ====================
# 复制此文件为 .env 并修改配置
# cp .env.template .env

# ==================== 大模型配置 ====================
# 通义千问 API Key（阿里云 DashScope）
API_KEY=sk-your-api-key-here
# API 地址（通义千问兼容 OpenAI 格式）
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 模型名称
LLM_MODEL=qwen3.5-flash
LLM_TEMPERATURE=0.1
LLM_STREAMING=True
LLM_ENABLE_THINKING=False

# ==================== 数据库配置 ====================
# MySQL（docker-compose 部署时默认 mysql 服务名）
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=travel123
MYSQL_DATABASE=smart_travel

# ==================== Milvus 向量数据库 ====================
# Milvus（docker-compose 部署时默认 milvus 服务名）
MILVUS_HOST=milvus
MILVUS_PORT=19530

# ==================== 数据源配置 ====================
# "database" = 从 MySQL 读取
DATA_SOURCE=database

# ==================== MinIO 对象存储（Milvus 依赖） ====================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ==================== MCP 服务器地址 ====================
# 各 A2A 服务连接 MCP Server 使用
# 本地运行默认: http://localhost:8001-8004/mcp
# Docker 运行自动使用服务名
# TICKET_MCP_URL=http://localhost:8001/mcp
# WEATHER_MCP_URL=http://localhost:8002/mcp
# TRIP_MCP_URL=http://localhost:8003/mcp
# GUIDE_MCP_URL=http://localhost:8004/mcp

# ==================== A2A 服务器地址 ====================
# 主服务连接各子 Agent 使用
# 本地运行默认: http://localhost:5005-5008
# Docker 运行自动使用服务名
# WEATHER_A2A_URL=http://localhost:5005
# TICKET_A2A_URL=http://localhost:5006
# TRIP_A2A_URL=http://localhost:5007
# GUIDE_A2A_URL=http://localhost:5008

# ==================== Reranker 模型（可选） ====================
# BGE-Reranker-v2-m3，首次运行自动下载（约 1.5GB）
# 不设置则回退到单阶段 ANN 检索
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
